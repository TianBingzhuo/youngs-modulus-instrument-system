<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YoungsModuleTest.Views.ExperimentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YoungsModuleTest.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 页面标题 -->
            <TextBlock Grid.Row="0" 
                       Text="实验中心" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Margin="0,0,0,24"/>

            <!-- 实验控制区域 -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 施加力控制 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,32,0">
                    <TextBlock Text="施加力(KG)：" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <NumberBox x:Name="AppliedForceBox"
                               PlaceholderText="请输入力值"
                               Minimum="0"
                               Maximum="100"
                               SmallChange="1.0"
                               LargeChange="5.0"
                               Width="120"
                               SpinButtonPlacementMode="Inline"/>
                </StackPanel>

                <!-- 实验材料输入 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,32,0">
                    <TextBlock Text="实验材料：" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="MaterialTypeTextBox"
                             PlaceholderText="请输入材料类型"
                             Width="120"
                             Text="锰钢"/>
                </StackPanel>

                <!-- 钢丝参数设置 -->
                <Button Grid.Column="2" 
                        x:Name="WireParametersButton"
                        Click="WireParametersButton_Click"
                        Margin="0,0,16,0"
                        ToolTipService.ToolTip="设置钢丝物理参数">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon FontFamily="Segoe Fluent Icons" 
                                  Glyph="&#xE99A;" 
                                  FontSize="14"
                                  Margin="0,0,4,0"/>
                        <TextBlock Text="钢丝参数"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 主要内容区域 - 固定双列布局 -->
            <Grid Grid.Row="2" x:Name="MainContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧区域 -->
                <StackPanel x:Name="LeftSection" Grid.Column="0">
                    <!-- 摄像头区域 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           x:Name="frameSourceName"
                                           Text="实验画面" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <ComboBox Grid.Column="1"
                                          x:Name="CameraSelectionComboBox"
                                          SelectionChanged="CameraSelectionComboBox_SelectionChanged"
                                          MinWidth="120"
                                          PlaceholderText="选择摄像头"/>
                            </Grid>

                            <Border Background="Black"
                                    CornerRadius="4"
                                    Height="240"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <MediaPlayerElement x:Name="captureElement" 
                                                        Stretch="UniformToFill" 
                                                        AutoPlay="True" />
                                    <TextBlock Text="摄像头未连接"
                                               x:Name="CameraStatusText"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"/>
                                </Grid>
                            </Border>

                            <!-- 摄像头控制按钮 -->
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Margin="0,8,0,0">
                                <Button x:Name="StartCameraButton"
                                        Click="StartCameraButton_Click"
                                        Content="启动摄像头"
                                        Margin="0,0,8,0"/>
                                <Button x:Name="CapturePhotoButton"
                                        Click="CapturePhoto_Click"
                                        IsEnabled="False"
                                        ToolTipService.ToolTip="拍照">
                                    <FontIcon FontFamily="Segoe Fluent Icons" 
                                              Glyph="&#xE722;" 
                                              FontSize="16"/>
                                </Button>
                            </StackPanel>

                            <!-- 拍照快照区域 -->
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock x:Name="capturedText" 
                                           Visibility="Collapsed" 
                                           Text="已捕获照片:" 
                                           FontSize="12"
                                           Margin="0,0,0,4"/>
                                <ScrollViewer VerticalScrollMode="Auto" 
                                              HorizontalScrollMode="Disabled" 
                                              MaxHeight="120">
                                    <Grid x:Name="snapshotsContainer">
                                        <StackPanel x:Name="snapshots" 
                                                    Orientation="Vertical"
                                                    HorizontalAlignment="Left">
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 实验状态区域 - 修改：隐藏杨氏模量和拟合质量 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="实验状态" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="当前施加力" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="CurrentForceText" 
                                               Text="0.0 KG" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                </StackPanel>

                                <!-- 隐藏杨氏模量显示，但保留元素以避免后端逻辑错误 -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Visibility="Collapsed">
                                    <TextBlock Text="杨氏模量" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="YoungsModulusText" 
                                               Text="-- GPa" 
                                               FontSize="20" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                                    <TextBlock Text="光照长度" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="IlluminatedLengthText" 
                                               Text="-- mm" 
                                               FontSize="16" 
                                               FontWeight="SemiBold" 
                                               Foreground="Purple"/>
                                </StackPanel>

                                <!-- 隐藏拟合质量显示，但保留元素以避免后端逻辑错误 -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Visibility="Collapsed">
                                    <TextBlock Text="拟合质量" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="FitQualityText" 
                                               Text="--" 
                                               FontSize="16" 
                                               FontWeight="SemiBold" 
                                               Foreground="DarkBlue"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="CCD状态" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="CCDStatusText" 
                                           Text="未连接" 
                                           FontSize="14" 
                                           Foreground="Red"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 右侧区域 -->
                <StackPanel x:Name="RightSection" Grid.Column="2">
                    <!-- CCD数据采集和绘图区域 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="CCD数据采集" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,12"/>

                            <!-- CCD控制面板 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 串口选择 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="串口:" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,8"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" 
                                          x:Name="SerialPortComboBox"
                                          SelectionChanged="SerialPortComboBox_SelectionChanged"
                                          Margin="0,0,8,8"
                                          PlaceholderText="选择串口"/>
                                <Button Grid.Row="0" Grid.Column="2"
                                        x:Name="RefreshPortsButton"
                                        Click="RefreshPortsButton_Click"
                                        Margin="0,0,0,8"
                                        ToolTipService.ToolTip="刷新串口列表">
                                    <FontIcon FontFamily="Segoe Fluent Icons" 
                                              Glyph="&#xE72C;" 
                                              FontSize="14"/>
                                </Button>

                                <!-- 积分时间选择 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="积分时间:" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,8"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                          x:Name="IntegrationTimeComboBox"
                                          SelectionChanged="IntegrationTimeComboBox_SelectionChanged"
                                          Margin="0,0,0,8"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="10 μs" Tag="0xB1"/>
                                    <ComboBoxItem Content="20 μs" Tag="0xB2"/>
                                    <ComboBoxItem Content="50 μs" Tag="0xB3"/>
                                    <ComboBoxItem Content="60 μs" Tag="0xB4"/>
                                    <ComboBoxItem Content="75 μs" Tag="0xB5"/>
                                    <ComboBoxItem Content="100 μs" Tag="0xB6"/>
                                    <ComboBoxItem Content="500 μs" Tag="0xB7"/>
                                    <ComboBoxItem Content="1.25 ms" Tag="0xB8"/>
                                    <ComboBoxItem Content="2.5 ms" Tag="0xB9"/>
                                    <ComboBoxItem Content="7.5 ms" Tag="0xBA"/>
                                </ComboBox>

                                <!-- 控制按钮 -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" 
                                            Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                    <Button x:Name="StartCCDButton"
                                            Click="StartCCDButton_Click"
                                            Content="开始采集"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="StopCCDButton"
                                            Click="StopCCDButton_Click"
                                            Content="停止采集"
                                            IsEnabled="False"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="RecordDataButton"
                                            Click="RecordDataButton_Click"
                                            Background="{ThemeResource AccentButtonBackground}"
                                            Foreground="{ThemeResource AccentButtonForeground}">
                                        <StackPanel Orientation="Horizontal">
                                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                                      Glyph="&#xE74E;" 
                                                      FontSize="14"
                                                      Margin="0,0,4,0"/>
                                            <TextBlock Text="记录数据"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- 绘图显示区域 -->
                            <Border Background="White"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Height="300"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <Canvas x:Name="CCDChart" Background="White"/>
                                    <TextBlock Text="等待CCD数据..."
                                               x:Name="ChartPlaceholderText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </Border>

                            <!-- 数据显示 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 第一行：基本统计数据 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="最大值" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="MaxValueText" Text="--" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="最小值" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="MinValueText" Text="--" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="平均值" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="AvgValueText" Text="--" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- 第二行：分界线相关数据 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock Text="边界位置" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="BoundaryPositionText" Text="--" FontSize="14" FontWeight="SemiBold" Foreground="Green"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock Text="激光区平均" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="LaserRegionAvgText" Text="--" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock Text="对比度" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="ContrastText" Text="--" FontSize="14" FontWeight="SemiBold" Foreground="DarkBlue"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 数据记录区域 - 修改：显示边界信息 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="测量数据记录" 
                                           FontSize="18" 
                                           FontWeight="SemiBold"/>

                                <Button Grid.Column="1"
                                        x:Name="ClearAllMeasurementsButton"
                                        Click="ClearAllMeasurementsButton_Click"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        ToolTipService.ToolTip="清除所有数据">
                                    <FontIcon FontFamily="Segoe Fluent Icons" 
                                              Glyph="&#xE74D;" 
                                              Foreground="Red"
                                              FontSize="16"/>
                                </Button>
                            </Grid>

                            <ListView x:Name="MeasurementsList" 
                                      Margin="0,12,0,0"
                                      MaxHeight="200"
                                      SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:MeasurementRecord">
                                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="4"
                                                Padding="8"
                                                Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{x:Bind SerialNumber}"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <Run Text="力: "/>
                                                        <Run Text="{x:Bind AppliedForce}" Foreground="LightGoldenrodYellow"/>
                                                        <Run Text=" KG"/>
                                                    </TextBlock>
                                                    <!-- 修改：显示边界信息而不是简单的长度 -->
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <Run Text="边界: "/>
                                                        <Run Text="{x:Bind LeftBoundary}" Foreground="LightBlue"/>
                                                        <Run Text="-"/>
                                                        <Run Text="{x:Bind RightBoundary}" Foreground="LightBlue"/>
                                                        <Run Text=" px"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <Run Text="区间: "/>
                                                        <Run Text="{x:Bind PixelLength}" Foreground="LightCoral"/>
                                                        <Run Text=" px ("/>
                                                        <Run Text="{x:Bind ActualLength}" Foreground="LightGreen"/>
                                                        <Run Text=" mm)"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{x:Bind Timestamp}" 
                                                               FontSize="10"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Click="DeleteMeasurementButton_Click"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Padding="4"
                                                        ToolTipService.ToolTip="删除此记录">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" 
                                                              Glyph="&#xE74D;" 
                                                              Foreground="Red"
                                                              FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 底部按钮区域 -->
            <Grid Grid.Row="3" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧实验结果 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="ExperimentResultText" 
                               Text="请施加载荷并开始CCD数据采集" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>

                <!-- 右侧操作按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ExportImageButton"
                            Click="ExportImageButton_Click"
                            Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                      Glyph="&#xE91B;" 
                                      FontSize="16"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="导出CCD数据"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ExportDataButton"
                            Click="ExportDataButton_Click"
                            Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                      Glyph="&#xE8FD;" 
                                      FontSize="16"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="保存实验报告"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ImportDataButton"
                            Click="ImportDataButton_Click"
                            Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                      Glyph="&#xE8B5;" 
                                      FontSize="16"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="导入历史数据"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
