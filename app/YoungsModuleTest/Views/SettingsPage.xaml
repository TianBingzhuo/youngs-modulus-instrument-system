<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YoungsModuleTest.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YoungsModuleTest.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="24">
            <StackPanel>
                <TextBlock Text="设置" FontSize="32" FontWeight="Bold" Margin="0,0,0,24"/>

                <!-- 关于部分 -->
                <Expander x:Name="AboutExpander" 
                          Header="关于" 
                          IsExpanded="False"
                          Margin="0,0,0,16">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" 
                                          FontFamily="Segoe Fluent Icons" 
                                          Glyph="&#xE946;" 
                                          FontSize="16"
                                          Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="1" 
                                           Text="关于" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </DataTemplate>
                    </Expander.HeaderTemplate>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,8,0,0">
                        <StackPanel>
                            <!-- 程序标题 -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" 
                                          FontFamily="Segoe Fluent Icons" 
                                          Glyph="&#xE802;" 
                                          FontSize="32"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                          Margin="0,0,16,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="杨氏模量测试仪" 
                                               FontSize="20" 
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Young's Modulus Tester" 
                                               FontSize="14" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <!-- 版本信息 -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="版本信息" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="版本: 1.0.0" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="构建: .NET 9.0" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="平台: Windows 11" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- 版权信息 -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="版权信息" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           LineHeight="18">
                                    <Run Text="©2025 河北工业大学杨氏模量实验仪小组 版权所有。"/><LineBreak/>
                                    <Run Text="本程序由田秉卓利用AI工具辅助制作。"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- 团队信息 -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="设计团队" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           LineHeight="18">
                                    <Run Text="指导教师：吴建海、宇霄"/><LineBreak/>
                                    <Run Text="设计学生：丁庆祥、朱兆兴、田秉卓、郭智美、赵思梦"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- 许可证信息 -->
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="开源许可" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           LineHeight="18">
                                    <Run Text="本程序以Apache License 2.0开源。"/><LineBreak/>
                                    <Run Text="完整许可证随本软件的工程携带，也可以在"/>
                                    <Hyperlink NavigateUri="https://www.apache.org/licenses/LICENSE-2.0">
                                        <Run Text="https://www.apache.org/licenses/LICENSE-2.0"/>
                                    </Hyperlink>
                                    <Run Text="获取。"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- 预留其他设置选项的位置 -->
                <TextBlock Text="其他设置选项将在此处显示..." 
                           FontSize="16" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
