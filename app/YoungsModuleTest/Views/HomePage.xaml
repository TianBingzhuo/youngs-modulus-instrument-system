<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YoungsModuleTest.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YoungsModuleTest.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 页面标题 -->
            <TextBlock Grid.Row="0" 
                       Text="首页" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Margin="0,0,0,24"/>

            <!-- 主要内容区域 - 修复响应式布局 -->
            <Grid Grid.Row="1" x:Name="ContentGrid">
                <!-- 始终保持两列布局，通过VisualState控制可见性和跨列 -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="LayoutStates">
                        <!-- 定义过渡动画 -->
                        <VisualStateGroup.Transitions>
                            <VisualTransition GeneratedDuration="0:0:0.3">
                                <VisualTransition.GeneratedEasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </VisualTransition.GeneratedEasingFunction>
                            </VisualTransition>
                        </VisualStateGroup.Transitions>

                        <VisualState x:Name="NarrowLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0"/>
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <!-- 窄屏：上下叠列 -->
                                <Setter Target="QuickAccessSection.Grid.Column" Value="0"/>
                                <Setter Target="QuickAccessSection.Grid.Row" Value="0"/>
                                <Setter Target="QuickAccessSection.Grid.ColumnSpan" Value="2"/>
                                <Setter Target="QuickAccessSection.Grid.RowSpan" Value="1"/>
                                <Setter Target="QuickAccessSection.Margin" Value="0,0,0,24"/>
                                <Setter Target="ExperimentRecordsSection.Grid.Column" Value="0"/>
                                <Setter Target="ExperimentRecordsSection.Grid.Row" Value="1"/>
                                <Setter Target="ExperimentRecordsSection.Grid.ColumnSpan" Value="2"/>
                                <Setter Target="ExperimentRecordsSection.Grid.RowSpan" Value="1"/>
                                <Setter Target="ExperimentRecordsSection.Margin" Value="0"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="WideLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="800"/>
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <!-- 宽屏：左右分列 -->
                                <Setter Target="QuickAccessSection.Grid.Column" Value="0"/>
                                <Setter Target="QuickAccessSection.Grid.Row" Value="0"/>
                                <Setter Target="QuickAccessSection.Grid.ColumnSpan" Value="1"/>
                                <Setter Target="QuickAccessSection.Grid.RowSpan" Value="2"/>
                                <Setter Target="QuickAccessSection.Margin" Value="0,0,32,0"/>
                                <Setter Target="ExperimentRecordsSection.Grid.Column" Value="1"/>
                                <Setter Target="ExperimentRecordsSection.Grid.Row" Value="0"/>
                                <Setter Target="ExperimentRecordsSection.Grid.ColumnSpan" Value="1"/>
                                <Setter Target="ExperimentRecordsSection.Grid.RowSpan" Value="2"/>
                                <Setter Target="ExperimentRecordsSection.Margin" Value="32,0,0,0"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <!-- 快速访问区域 -->
                <StackPanel x:Name="QuickAccessSection" Grid.Column="0" Grid.Row="0">
                    <TextBlock Text="快速访问" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,12"/>

                    <GridView x:Name="QuickAccessGrid" 
                              SelectionMode="Single"
                              ItemClick="QuickAccessGrid_ItemClick"
                              IsItemClickEnabled="True">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:QuickAccessItem">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        Padding="16"
                                        Width="120"
                                        Height="100">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon FontFamily="Segoe Fluent Icons" 
                                                  Glyph="{x:Bind IconGlyph}" 
                                                  FontSize="32"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,8"/>
                                        <TextBlock Text="{x:Bind Title}" 
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                    </GridView>
                </StackPanel>

                <!-- 实验记录区域 -->
                <StackPanel x:Name="ExperimentRecordsSection" Grid.Column="1" Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="实验记录" 
                                   FontSize="20" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                x:Name="ClearAllRecordsButton"
                                Click="ClearAllRecordsButton_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                ToolTipService.ToolTip="清除所有记录">
                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                      Glyph="&#xE74D;" 
                                      Foreground="Red"
                                      FontSize="16"/>
                        </Button>
                    </Grid>

                    <ListView x:Name="ExperimentRecordsList" 
                              Margin="0,12,0,0"
                              MaxHeight="400">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ExperimentRecord">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Bind Name}" 
                                                       FontWeight="SemiBold"
                                                       FontSize="14"/>
                                            <TextBlock Text="{x:Bind DateTime}" 
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind Description}" 
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Click="OpenRecordButton_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Margin="8,0"
                                                ToolTipService.ToolTip="打开记录">
                                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                                      Glyph="&#xE8E5;" 
                                                      FontSize="14"/>
                                        </Button>

                                        <Button Grid.Column="2"
                                                Click="DeleteRecordButton_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                ToolTipService.ToolTip="删除记录">
                                            <FontIcon FontFamily="Segoe Fluent Icons" 
                                                      Glyph="&#xE74D;" 
                                                      Foreground="Red"
                                                      FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
